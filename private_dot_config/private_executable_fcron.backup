#!/bin/sh
@ 01 topydo ls -f ical > $HOME/.local/share/calendars/todo/todo.ics
@ 01 jrnl --format md > $HOME/Documents/Notes/Personal/Journal/GTD/Journal.md
@ 15 CALCURSE_CALDAV_PASSWORD=$(pass show calcurse) calcurse-caldav
@ 15 $HOME/.local/bin/scripts/syncmail ; date &>/tmp/cron-syncmail.log
@ 30 sfeed_update ~/.config/sfeed/sfeedrc $>/var/log/cron-sfeed.log
@ 30 sfeed_html $HOME/.local/share/sfeed/feeds/* > $HOME/.local/share/sfeed/feeds.html
@ 30 sfeed_plain $HOME/.local/share/sfeed/feeds/* > $HOME/.local/share/sfeed/feeds.txt
@ 60 calcurse -x > $HOME/.local/share/calendars/main/main.ics
@ 60 rm $HOME/core
@ 60 rm $HOME/.bg
@ 60 rm $HOME/.yarnrc
@ 60 rm $HOME/package.json
@ 60 rm $HOME/package-lock.json
@ 60 rm $HOME/.autotiling.bolt
@ 60 rm -r $HOME/.npm
@ 60 rm -r $HOME/node_modules
@ 60 rm -r $HOME/.node-gyp
@ 60 rm -r $HOME/.electron
@ 60 rm -r $HOME/.electron-gyp
@ 60 rm -r $HOME/.nuget
@ 60 rm -r $HOME/.dotnet
@ 20160 notify-send "Upgrade system"
@ 20160 notify-send "Clear caches"
%daily * 23 moonphase
%daily * 23 flavours update all
%daily * 23 fcrontab -l > $HOME/.config/fcron.backup
%daily * 23 dconf dump / > $HOME/.config/saved_settings.dconf
#%daily * 23 rsync -rtvzP $HOME/.mozilla/firefox/rpp6gs0y.default/extension* $HOME/.mozilla/firefox/rpp6gs0y.default/search.json.mozlz4 $HOME/.mozilla/firefox/rpp6gs0y.default/addons.json $HOME/.mozilla/firefox/rpp6gs0y.default/prefs.js $HOME/.config/firefox/new-profile
%daily * 23 rsync -rtvzP $HOME/.mozilla/firefox/rpp6gs0y.default/bookmarkbackups/ $HOME/.local/share/urls
%daily * 23 newsboat --url-file=~/.config/newsboat/daily-list -x print-unread | awk '{print $1;}' > $HOME/.config/newsboat/today-unread-count
%daily * 23 poku --access $(pass show poku) --consumer $(pass show consumer) ; buku -e $HOME/Documents/Notes/Personal/Journal/Collections/References/buku.md
%daily * 23 tree -f -L 1 -I "*.txt|*.html|*/" $ZET_DIR > $ZET_DIR/001-tree.txt
%daily * 23 tree-index-md $ZET_DIR > $ZET_DIR/000-index.md
%daily * 23 markmap $ZET_DIR/000-index.md > $ZET_DIR/000-index.html
